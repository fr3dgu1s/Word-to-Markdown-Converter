# Word-to-Markdown Converter — runtime path configuration
#
# All runtime files are routed through C:/temp/W2MD by default so the app
# never depends on per-user (C:\Users\...) locations. Override any value
# below by editing this file (copied to .env) or by setting the same name
# as a Windows environment variable.
#
# Use forward slashes ("/") to avoid having to escape backslashes.

# Base folder for all runtime files (outputs, temp, logs, helper).
APP_DATA_ROOT=C:/temp/W2MD

# Converted Markdown, images, batch outputs, and final exports.
OUTPUTS_ROOT=C:/temp/W2MD/Outputs

# Temporary files: cloud downloads, decrypted MIP working copies.
TEMP_ROOT=C:/temp/W2MD/Temp

# Application logs (app.log + rotated backups).
LOGS_ROOT=C:/temp/W2MD/Logs

# Folder where the published MIP helper is copied at setup time.
MIP_HELPER_ROOT=C:/temp/W2MD/MipHelper

# Full path to MipHelper.exe. The Python orchestrator falls back to
# searching MIP_HELPER_ROOT and the repo-relative publish output if this
# path is unset or missing.
MIP_HELPER_PATH=C:/temp/W2MD/MipHelper/MipHelper.exe

# UPN of the signed-in user. Forwarded to MipHelper.exe so the helper can
# acquire a delegated MIP token bound to this identity.
MIP_USER_UPN=
