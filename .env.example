# Word-to-Markdown Converter — runtime path configuration
#
# By default, runtime files are stored in the project/app folder that contains
# paths.py. Leave APP_DATA_ROOT unset to use that default.
#
# Effective default layout:
#   APP_DATA_ROOT=<project folder>
#   OUTPUTS_ROOT=<project folder>\Outputs
#   IMAGES_ROOT=<project folder>\Outputs\Images
#   TEMP_ROOT=<project folder>\Temp
#   LOGS_ROOT=<project folder>\Logs
#
# To move all runtime files elsewhere, copy this file to .env and uncomment
# APP_DATA_ROOT below. Use forward slashes ("/") to avoid escaping backslashes.

# APP_DATA_ROOT=C:/path/to/Word-to-Markdown-Converter
