# Path to the compiled C# helper. If unset, the app probes
# MipHelper/bin/{Release,Debug}/net8.0/MipHelper.exe under the repo root.
MIP_HELPER_PATH=

# Optional folder containing MipHelper.exe. Used as a fallback when
# MIP_HELPER_PATH is not set.
MIP_HELPER_DIR=

# UPN of the currently signed-in user. Forwarded to MipHelper.exe so the
# helper can acquire a delegated MIP token bound to this identity.
MIP_USER_UPN=
